<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ================================================================
         NAVBAR BUTTON
         Appears in the systray (top-right navbar area).
         Shows a small AI spark icon. Pulses when loading.
    ================================================================ -->
    <t t-name="copilot_base.CopilotButton">
        <div class="cop-btn" t-on-click="onClick" t-att-class="{ 'cop-btn--active': isOpen }">
            <svg class="cop-icon" t-att-class="{ 'cop-icon--spin': isOpen }"
                 width="18" height="18" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
                <!-- Spark / AI icon -->
                <path d="M12 2L13.5 9L20 12L13.5 15L12 22L10.5 15L4 12L10.5 9L12 2Z"
                      fill="currentColor" opacity="0.9"/>
                <circle cx="12" cy="12" r="2.5" fill="none" stroke="currentColor"
                        stroke-width="1.2" opacity="0.5"/>
            </svg>
            <span class="cop-btn-label">Copilot</span>
        </div>
    </t>

    <!-- ================================================================
         CHAT PANEL
         Slides up from the bottom-right corner.
    ================================================================ -->
    <t t-name="copilot_base.CopilotPanel">
        <div class="cop-panel-wrapper" t-att-class="{ 'cop-panel-wrapper--open': isOpen }">
            <div class="cop-panel">

                <!-- Header -->
                <div class="cop-header">
                    <div class="cop-header-left">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             class="cop-header-icon">
                            <path d="M12 2L13.5 9L20 12L13.5 15L12 22L10.5 15L4 12L10.5 9L12 2Z"
                                  fill="currentColor"/>
                        </svg>
                        <span class="cop-header-title">Copilot</span>
                        <span class="cop-context-badge" t-if="state.currentContext.model">
                            <t t-esc="contextLabel"/>
                        </span>
                    </div>
                    <div class="cop-header-actions">
                        <button class="cop-icon-btn" t-on-click="onClear" title="New chat">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"
                                      stroke="currentColor" stroke-width="1.8"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                        <button class="cop-icon-btn" t-on-click="onClose" title="Close">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <path d="M18 6L6 18M6 6l12 12"
                                      stroke="currentColor" stroke-width="1.8"
                                      stroke-linecap="round"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Messages list -->
                <div class="cop-messages" t-ref="messagesList">

                    <!-- Empty state -->
                    <div class="cop-empty" t-if="messages.length === 0 and !isLoading">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                             class="cop-empty-icon">
                            <path d="M12 2L13.5 9L20 12L13.5 15L12 22L10.5 15L4 12L10.5 9L12 2Z"
                                  fill="currentColor" opacity="0.25"/>
                        </svg>
                        <p class="cop-empty-title">How can I help?</p>
                        <p class="cop-empty-sub" t-if="state.currentContext.model">
                            I can see you're on <strong t-esc="contextLabel"/>.
                            Ask me anything about this record.
                        </p>
                        <p class="cop-empty-sub" t-else="">
                            Ask me anything about your Odoo data.
                        </p>
                    </div>

                    <!-- Message bubbles -->
                    <t t-foreach="messages" t-as="msg" t-key="msg_index">
                        <div class="cop-message"
                             t-att-class="{
                               'cop-message--user': msg.role === 'user',
                               'cop-message--assistant': msg.role === 'assistant'
                             }">
                            <div class="cop-bubble">
                                <t t-if="msg.role === 'assistant'">
                                    <div t-out="formatMessage(msg.content)"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="msg.content"/>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- Thinking indicator -->
                    <div class="cop-message cop-message--assistant" t-if="isLoading">
                        <div class="cop-bubble cop-bubble--thinking">
                            <span class="cop-dot"/>
                            <span class="cop-dot"/>
                            <span class="cop-dot"/>
                        </div>
                    </div>

                    <!-- Error -->
                    <div class="cop-error" t-if="error">
                        <t t-esc="error"/>
                    </div>

                </div>

                <!-- Input area -->
                <div class="cop-input-area">
                    <textarea
                        class="cop-input"
                        t-ref="messageInput"
                        placeholder="Ask about this page..."
                        rows="1"
                        t-on-keydown="onKeyDown"
                        t-on-input="onInputResize"
                    />
                    <button
                        class="cop-send-btn"
                        t-on-click="onSend"
                        t-att-disabled="isLoading"
                    >
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M22 2L11 13M22 2L15 22L11 13L2 9L22 2Z"
                                  fill="currentColor"/>
                        </svg>
                    </button>
                </div>

            </div>
        </div>
    </t>

</templates>