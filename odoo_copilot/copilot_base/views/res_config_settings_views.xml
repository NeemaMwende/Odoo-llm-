<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_copilot" model="ir.ui.view">
        <field name="name">res.config.settings.view.copilot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Copilot AI" string="Copilot AI"
                     data-key="copilot_base">
                    <h2>Copilot AI</h2>
                    <div class="row mt16">
                        <label class="col-lg-4 o_light_label" for="copilot_provider_type">
                            Provider
                        </label>
                        <field name="copilot_provider_type"/>
                    </div>
                    <div class="row mt16">
                        <label class="col-lg-4 o_light_label" for="copilot_system_prompt">
                            System Prompt
                        </label>
                        <field name="copilot_system_prompt" widget="text" style="height:80px"/>
                    </div>
                    <div class="row mt16">
                        <label class="col-lg-4 o_light_label" for="copilot_max_history">
                            Max History Messages
                        </label>
                        <field name="copilot_max_history"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>